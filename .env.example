# Lobster runtime configuration. Copy this file to .env (or to a sibling
# secret.mjs that exports the values) and fill in the values for your bot
# and database.

# Discord
DISCORD_TOKEN=
LOBSTER_ID=
DARKSIDE_ID=

# Filesystem layout. Should point at the directory that contains this file.
LOBSTER_ROOT=

# When set to anything truthy, System#pull skips `git pull` on boot.
NO_GIT_PULL=

# MySQL connection. Used by ../secret.mjs (LobsterConfig). Example values
# left intentionally blank — fill them in for your local environment.
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
